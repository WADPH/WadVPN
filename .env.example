# WadVPN deployment configuration. Copy to .env and adjust for this server.
WADVPN_PROJECT_NAME=WadVPN
WADVPN_PROJECT_VERSION=1.0.0

# The hostname is preferred for generated client endpoints. PUBLIC_IP is used
# only when PUBLIC_HOSTNAME is empty.
WADVPN_PUBLIC_HOSTNAME=vpn.example.com
WADVPN_PUBLIC_IP=203.0.113.10
WADVPN_WAN_INTERFACE=ens3

WADVPN_WG_INTERFACE=wg0
WADVPN_WG_ADDRESS=10.200.0.1/24
WADVPN_WG_LISTEN_PORT=51820
WADVPN_VPN_NETWORK=10.200.0.0/24

# Comma-separated DNS servers included in generated client configurations.
WADVPN_DNS_SERVERS=1.1.1.1,1.0.0.1
